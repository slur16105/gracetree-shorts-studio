{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gracetree.local/schemas/engine-command.schema.json",
  "title": "Engine command",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "check_health" },
        "jobId": { "type": "string", "minLength": 1 },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": { "type": "object", "additionalProperties": false }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "get_or_create_job" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["publishDate", "managedRoot", "workPath"],
          "properties": {
            "publishDate": { "type": "string", "format": "date" },
            "managedRoot": { "type": "string", "minLength": 1 },
            "workPath": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "register_input_files" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sourcePaths", "managedRoot"],
          "properties": {
            "sourcePaths": {
              "type": "array",
              "minItems": 1,
              "maxItems": 100,
              "items": { "type": "string", "minLength": 1 }
            },
            "managedRoot": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "manage_input" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "inputId", "role", "managedRoot"],
              "properties": {
                "action": { "const": "assign_role" },
                "inputId": { "type": "string", "format": "uuid" },
                "role": {
                  "enum": ["thumbnail", "voice", "bgm", "script", "unclassified"]
                },
                "managedRoot": { "type": "string", "minLength": 1 }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "inputId", "managedRoot"],
              "properties": {
                "action": { "const": "remove" },
                "inputId": { "type": "string", "format": "uuid" },
                "managedRoot": { "type": "string", "minLength": 1 }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["action", "inputId", "sourcePath", "managedRoot"],
              "properties": {
                "action": { "const": "replace" },
                "inputId": { "type": "string", "format": "uuid" },
                "sourcePath": { "type": "string", "minLength": 1 },
                "managedRoot": { "type": "string", "minLength": 1 }
              }
            }
          ]
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "get_resources" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["managedRoot"],
          "properties": { "managedRoot": { "type": "string", "minLength": 1 } }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "update_resource" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["resourceType", "sourcePath", "managedRoot"],
          "properties": {
            "resourceType": { "enum": ["title_scripture_video", "prayer_loop_video", "default_bgm", "subtitle_font"] },
            "sourcePath": { "type": "string", "minLength": 1 },
            "managedRoot": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "list_completed_jobs" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["managedRoot"],
          "properties": { "managedRoot": { "type": "string", "minLength": 1 } }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "validate_script" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inputId", "inputVersion", "managedPath"],
          "properties": {
            "inputId": { "type": "string", "format": "uuid" },
            "inputVersion": { "type": "string", "minLength": 1 },
            "managedPath": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  ]
}
