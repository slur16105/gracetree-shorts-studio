{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gracetree.local/schemas/engine-event.schema.json",
  "title": "Engine event",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "health_checked" },
        "jobId": { "type": "string", "minLength": 1 },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": { "status": { "const": "ok" } }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "job_loaded" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["job"],
          "properties": {
            "job": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "publishDate",
                "status",
                "title",
                "workPath",
                "resultPath",
                "createdAt",
                "updatedAt",
                "pathState",
                "inputMetadata"
              ],
              "properties": {
                "id": { "type": "string", "format": "uuid" },
                "publishDate": { "type": "string", "format": "date" },
                "status": {
                  "enum": [
                    "draft",
                    "running",
                    "completed",
                    "failed",
                    "cancelled",
                    "interrupted"
                  ]
                },
                "title": { "type": ["string", "null"] },
                "workPath": { "type": "string", "minLength": 1 },
                "resultPath": { "type": "string", "minLength": 1 },
                "createdAt": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "Z$"
                },
                "updatedAt": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "Z$"
                },
                "pathState": { "enum": ["ready", "missing"] },
                "inputMetadata": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/jobInput" }
                }
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "input_files_registered" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["results", "inputs"],
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "originalName",
                  "managedPath",
                  "role",
                  "status",
                  "errorCode"
                ],
                "properties": {
                  "originalName": { "type": "string", "minLength": 1 },
                  "managedPath": { "type": ["string", "null"] },
                  "role": {
                    "enum": ["thumbnail", "voice", "bgm", "script", "unclassified"]
                  },
                  "status": { "enum": ["registered", "rejected", "conflict"] },
                  "errorCode": {
                    "enum": [
                      "UNSUPPORTED_TYPE",
                      "SOURCE_UNREADABLE",
                      "SOURCE_INSIDE_MANAGED_ROOT",
                      "SYMLINK_NOT_ALLOWED",
                      "FILE_TOO_LARGE",
                      "NAME_CONFLICT",
                      "COPY_FAILED",
                      null
                    ]
                  },
                  "input": { "$ref": "#/$defs/jobInput" }
                },
                "oneOf": [
                  {
                    "required": ["input"],
                    "properties": {
                      "input": { "$ref": "#/$defs/jobInput" },
                      "status": { "const": "registered" },
                      "managedPath": { "type": "string", "minLength": 1 },
                      "errorCode": { "type": "null" }
                    }
                  },
                  {
                    "properties": {
                      "input": false,
                      "status": { "const": "rejected" },
                      "managedPath": { "type": "null" },
                      "errorCode": {
                        "enum": [
                          "UNSUPPORTED_TYPE",
                          "SOURCE_UNREADABLE",
                          "SOURCE_INSIDE_MANAGED_ROOT",
                          "SYMLINK_NOT_ALLOWED",
                          "FILE_TOO_LARGE",
                          "COPY_FAILED"
                        ]
                      }
                    }
                  },
                  {
                    "properties": {
                      "input": false,
                      "status": { "const": "conflict" },
                      "managedPath": { "type": "string", "minLength": 1 },
                      "errorCode": { "const": "NAME_CONFLICT" }
                    }
                  }
                ]
              }
            },
            "inputs": {
              "type": "array",
              "items": { "$ref": "#/$defs/jobInput" }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "input_state_changed" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inputs"],
          "properties": {
            "inputs": {
              "type": "array",
              "items": { "$ref": "#/$defs/jobInput" }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "resources_loaded" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["resources"],
          "properties": {
            "resources": { "type": "array", "items": { "$ref": "#/$defs/resource" } }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "resource_updated" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["resources", "error"],
          "properties": {
            "resources": { "type": "array", "items": { "$ref": "#/$defs/resource" } },
            "error": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["resourceType", "code", "message"],
                  "properties": {
                    "resourceType": { "enum": ["title_scripture_video", "prayer_loop_video", "default_bgm", "subtitle_font"] },
                    "code": { "enum": ["MANAGED_ROOT_MISSING", "SOURCE_UNREADABLE", "UNSUPPORTED_FORMAT", "COPY_FAILED"] },
                    "message": { "type": "string", "minLength": 1 }
                  }
                }
              ]
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "completed_jobs_listed" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["jobs"],
          "properties": {
            "jobs": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "publishDate", "title", "completedAt", "resultPath"],
                "properties": {
                  "id": { "type": "string", "format": "uuid" },
                  "publishDate": { "type": "string", "format": "date" },
                  "title": { "type": ["string", "null"] },
                  "completedAt": { "type": "string", "format": "date-time", "pattern": "Z$" },
                  "resultPath": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "script_validated" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inputId", "inputVersion", "status", "oneLiner", "sections", "errors"],
          "properties": {
            "inputId": { "type": "string", "format": "uuid" },
            "inputVersion": { "type": "string", "minLength": 1 },
            "status": { "enum": ["valid", "invalid"] },
            "oneLiner": { "type": ["string", "null"] },
            "sections": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "scripture", "prayer"],
              "properties": {
                "title": { "type": ["string", "null"] },
                "scripture": { "type": ["string", "null"] },
                "prayer": { "type": ["string", "null"] }
              }
            },
            "errors": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["code", "section", "message"],
                "properties": {
                  "code": {
                    "enum": [
                      "FILE_UNREADABLE",
                      "FILE_EMPTY",
                      "SECTION_MISSING",
                      "SECTION_EMPTY",
                      "SECTION_DUPLICATE"
                    ]
                  },
                  "section": {
                    "enum": ["title", "scripture", "prayer", null]
                  },
                  "message": { "type": "string", "minLength": 1 }
                }
              }
            },
            "ast": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["title", "scripture", "subtitleBlocks"],
                  "properties": {
                    "title": { "type": "string" },
                    "scripture": { "type": "string" },
                    "subtitleBlocks": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["index", "text", "lines"],
                        "properties": {
                          "index": { "type": "integer", "minimum": 0 },
                          "text": { "type": "string" },
                          "lines": { "type": "array", "items": { "type": "string" } }
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "job_accepted" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attemptId"],
          "properties": {
            "attemptId": { "type": "string", "format": "uuid" }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "stage_started" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attemptId", "stageId", "stageName"],
          "properties": {
            "attemptId": { "type": "string", "format": "uuid" },
            "stageId": { "enum": ["vertical_slice"] },
            "stageName": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "progress" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attemptId", "stageId", "percent"],
          "properties": {
            "attemptId": { "type": "string", "format": "uuid" },
            "stageId": { "enum": ["vertical_slice"] },
            "percent": { "type": "integer", "minimum": 0, "maximum": 99 }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "artifact_created" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attemptId", "artifactPath", "artifactName"],
          "properties": {
            "attemptId": { "type": "string", "format": "uuid" },
            "artifactPath": { "type": "string", "minLength": 1 },
            "artifactName": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "job_completed" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attemptId", "artifactPath", "artifactName"],
          "properties": {
            "attemptId": { "type": "string", "format": "uuid" },
            "artifactPath": { "type": "string", "minLength": 1 },
            "artifactName": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "job_failed" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attemptId", "errorCode", "stageId"],
          "properties": {
            "attemptId": { "type": "string", "format": "uuid" },
            "errorCode": { "type": "string", "minLength": 1 },
            "stageId": { "oneOf": [{ "enum": ["vertical_slice"] }, { "type": "null" }] }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "job_cancelled" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attemptId"],
          "properties": {
            "attemptId": { "type": "string", "format": "uuid" }
          }
        }
      }
    }
  ],
  "$defs": {
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "managedPath", "status", "updatedAt"],
      "properties": {
        "type": { "enum": ["title_scripture_video", "prayer_loop_video", "default_bgm", "subtitle_font"] },
        "managedPath": { "type": ["string", "null"] },
        "status": { "enum": ["ready", "missing", "invalid"] },
        "updatedAt": { "type": "string", "format": "date-time", "pattern": "Z$" }
      },
      "if": { "properties": { "status": { "const": "ready" } }, "required": ["status"] },
      "then": { "properties": { "managedPath": { "type": "string", "minLength": 1 } } }
    },
    "jobInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "jobId",
        "role",
        "originalName",
        "managedPath",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "jobId": { "type": "string", "format": "uuid" },
        "role": {
          "enum": ["thumbnail", "voice", "bgm", "script", "unclassified"]
        },
        "originalName": { "type": "string", "minLength": 1 },
        "managedPath": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["ready", "conflict", "unclassified", "invalid"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        }
      }
    }
  }
}
