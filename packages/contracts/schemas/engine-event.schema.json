{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gracetree.local/schemas/engine-event.schema.json",
  "title": "Engine event",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "health_checked" },
        "jobId": { "type": "string", "minLength": 1 },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": { "status": { "const": "ok" } }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "job_loaded" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["job"],
          "properties": {
            "job": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "publishDate",
                "status",
                "title",
                "workPath",
                "resultPath",
                "createdAt",
                "updatedAt",
                "pathState",
                "inputMetadata"
              ],
              "properties": {
                "id": { "type": "string", "format": "uuid" },
                "publishDate": { "type": "string", "format": "date" },
                "status": {
                  "enum": [
                    "draft",
                    "running",
                    "completed",
                    "failed",
                    "cancelled",
                    "interrupted"
                  ]
                },
                "title": { "type": ["string", "null"] },
                "workPath": { "type": "string", "minLength": 1 },
                "resultPath": { "type": "string", "minLength": 1 },
                "createdAt": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "Z$"
                },
                "updatedAt": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "Z$"
                },
                "pathState": { "enum": ["ready", "missing"] },
                "inputMetadata": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/jobInput" }
                }
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "input_files_registered" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["results", "inputs"],
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "originalName",
                  "managedPath",
                  "role",
                  "status",
                  "errorCode"
                ],
                "properties": {
                  "originalName": { "type": "string", "minLength": 1 },
                  "managedPath": { "type": ["string", "null"] },
                  "role": {
                    "enum": ["thumbnail", "voice", "bgm", "script", "unclassified"]
                  },
                  "status": { "enum": ["registered", "rejected", "conflict"] },
                  "errorCode": {
                    "enum": [
                      "UNSUPPORTED_TYPE",
                      "SOURCE_UNREADABLE",
                      "SOURCE_INSIDE_MANAGED_ROOT",
                      "SYMLINK_NOT_ALLOWED",
                      "FILE_TOO_LARGE",
                      "NAME_CONFLICT",
                      "COPY_FAILED",
                      null
                    ]
                  },
                  "input": { "$ref": "#/$defs/jobInput" }
                },
                "oneOf": [
                  {
                    "required": ["input"],
                    "properties": {
                      "input": { "$ref": "#/$defs/jobInput" },
                      "status": { "const": "registered" },
                      "managedPath": { "type": "string", "minLength": 1 },
                      "errorCode": { "type": "null" }
                    }
                  },
                  {
                    "properties": {
                      "input": false,
                      "status": { "const": "rejected" },
                      "managedPath": { "type": "null" },
                      "errorCode": {
                        "enum": [
                          "UNSUPPORTED_TYPE",
                          "SOURCE_UNREADABLE",
                          "SOURCE_INSIDE_MANAGED_ROOT",
                          "SYMLINK_NOT_ALLOWED",
                          "FILE_TOO_LARGE",
                          "COPY_FAILED"
                        ]
                      }
                    }
                  },
                  {
                    "properties": {
                      "input": false,
                      "status": { "const": "conflict" },
                      "managedPath": { "type": "string", "minLength": 1 },
                      "errorCode": { "const": "NAME_CONFLICT" }
                    }
                  }
                ]
              }
            },
            "inputs": {
              "type": "array",
              "items": { "$ref": "#/$defs/jobInput" }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "jobId", "timestamp", "payload"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "type": { "const": "input_state_changed" },
        "jobId": { "type": "string", "format": "uuid" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inputs"],
          "properties": {
            "inputs": {
              "type": "array",
              "items": { "$ref": "#/$defs/jobInput" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "jobInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "jobId",
        "role",
        "originalName",
        "managedPath",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "jobId": { "type": "string", "format": "uuid" },
        "role": {
          "enum": ["thumbnail", "voice", "bgm", "script", "unclassified"]
        },
        "originalName": { "type": "string", "minLength": 1 },
        "managedPath": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["ready", "conflict", "unclassified", "invalid"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        }
      }
    }
  }
}
